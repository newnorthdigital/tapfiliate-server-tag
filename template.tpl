___SANDBOXED_JS_FOR_SERVER___

const sendHttpRequest = require('sendHttpRequest');
const JSON = require('JSON');
const getRequestHeader = require('getRequestHeader');
const makeNumber = require('makeNumber');
const logToConsole = require('logToConsole');

const apiKey = data.api_key;
const operationType = data.operation_type;
const externalId = data.external_id;
const customerId = data.customer_id;
const enableDebug = data.debug;

const debugLog = (message) => {
  if (enableDebug) {
    logToConsole('Tapfiliate sGTM - ' + message);
  }
};

debugLog('Starting operation: ' + operationType);

// Affiliate identification (priority: coupon > click_id > referral_code)
const referralCode = data.referral_code;
const coupon = data.coupon;
const clickId = data.click_id;

// Conversion specific
const amount = data.amount;
const currency = data.currency;
const status = data.status;

// API endpoints
const API_BASE = 'https://api.tapfiliate.com/1.7/pb';
const endpoints = {
  'create_conversion': API_BASE + '/con/c/',
  'update_conversion': API_BASE + '/con/u/',
  'create_customer': API_BASE + '/cus/c/',
  'update_customer': API_BASE + '/cus/u/'
};

const buildPayload = () => {
  let payload = {};

  if (operationType.indexOf('conversion') !== -1 && externalId) {
    payload.external_id = externalId;
  }

  if (operationType.indexOf('customer') !== -1 && customerId) {
    payload.customer_id = customerId;
  }

  // Affiliate identification (only for create operations)
  if (operationType.indexOf('create') !== -1) {
    if (coupon) {
      payload.coupon = coupon;
    } else if (clickId) {
      payload.click_id = clickId;
    } else if (referralCode) {
      payload.referral_code = referralCode;
    }
  }

  if (amount !== undefined && amount !== null && amount !== '') {
    payload.amount = makeNumber(amount);
  }

  if (currency) {
    payload.currency = currency;
  }

  if (operationType.indexOf('update') !== -1 && status) {
    payload.status = status;
  }

  // Meta data
  if (data.meta_data) {
    const parsed = JSON.parse(data.meta_data);
    if (parsed) {
      payload.meta_data = parsed;
    }
  }

  // Auto-detect user agent and IP from request headers
  const userAgent = getRequestHeader('User-Agent');
  if (userAgent) {
    payload.user_agent = userAgent;
  }

  const clientIp = getRequestHeader('X-Forwarded-For') || getRequestHeader('X-Real-IP');
  if (clientIp) {
    payload.ip = clientIp;
  }

  debugLog('Payload built with keys: ' + JSON.stringify(payload));
  return payload;
};

const validateParams = () => {
  if (!apiKey) return 'API token is required';
  if (!operationType) return 'Operation type is required';

  switch (operationType) {
    case 'create_conversion':
      if (!externalId) return 'Transaction ID is required for conversion creation';
      if (!referralCode && !coupon && !clickId) return 'At least one affiliate identifier (referral_code, coupon, or click_id) is required';
      break;
    case 'update_conversion':
      if (!externalId) return 'Transaction ID is required for conversion update';
      break;
    case 'create_customer':
      if (!customerId) return 'Customer ID is required for customer creation';
      if (!referralCode && !coupon && !clickId) return 'At least one affiliate identifier is required';
      break;
    case 'update_customer':
      if (!customerId) return 'Customer ID is required for customer update';
      break;
  }

  return null;
};

// Main execution
const validationError = validateParams();
if (validationError) {
  debugLog('Validation failed: ' + validationError);
  data.gtmOnFailure();
  return;
}

const endpoint = endpoints[operationType];
const payload = buildPayload();

debugLog('Sending request to: ' + endpoint);

sendHttpRequest(endpoint, (statusCode, headers, body) => {
  debugLog('Response status: ' + statusCode);
  if (statusCode >= 200 && statusCode < 300) {
    debugLog('Request successful');
    data.gtmOnSuccess();
  } else {
    debugLog('Request failed: ' + body);
    data.gtmOnFailure();
  }
}, {
  headers: {
    'Content-Type': 'application/json',
    'X-Api-Key': apiKey
  },
  method: 'POST'
}, JSON.stringify(payload));


